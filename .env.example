# ─────────────────────────────────────────────────────────────────────────────
# MMB AGENT 24/7 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED — Backend API security key ──────────────────────────────────────
# Any random string. Must match between server and frontend.
BACKEND_API_KEY=mmb-local-dev-2025
VITE_BACKEND_API_KEY=mmb-local-dev-2025

# ── MoreLogin (local desktop app) ────────────────────────────────────────────
# Get from: MoreLogin app → Settings → API Key
# Can also be set from Settings page in the UI (no restart needed).
MORELOGIN_API_KEY=
MORELOGIN_PORT=40000

# ── Multilogin ───────────────────────────────────────────────────────────────
# Option A (recommended): 30-day automation token
#   GET https://api.multilogin.com/workspace/automation_token?expiration_period=720h
MULTILOGIN_TOKEN=
MULTILOGIN_FOLDER_ID=

# Option B: Email + Password (if no automation token)
MULTILOGIN_EMAIL=
MULTILOGIN_PASSWORD=

# ── Active browser provider ───────────────────────────────────────────────────
# Options: morelogin | multilogin | all
# Can also be changed from Settings → Browser Provider in the UI.
BROWSER_PROVIDER=morelogin

# ── Smartproxy ───────────────────────────────────────────────────────────────
# Can be set from Settings page — no restart needed.
PROXY_SERVER=us.smartproxy.net
PROXY_PORT=3120
PROXY_PASSWORD=
PROXY_PREFIX=
DEFAULT_PROXY_LIFE=4hr

# ── Notifications (optional) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI Brain (optional) ──────────────────────────────────────────────────────
# Anthropic API key for Claude Haiku decision-making per profile.
ANTHROPIC_API_KEY=
